/genesis-out
/snapshot-cache
.vercel

# Out-of-tree wasm package (built and published to npm separately)
/proofs-pkg

# ── SECRETS: private keypairs — NEVER commit (enumerated 2026-06-16) ──
# 3 authority keypairs: lazy-claim-v2 / megadrop-v2 / validator-subsidy-v2
/keys/
# 17 surfpool test-ledger keypairs (faucet/stake/validator/vote + payer) live here;
# dir is also ~890M of regenerable surfpool artifacts.
/.codex-whirlpools-artifacts/
# Defense-in-depth: catch any solana-keygen output (faucet/vote/stake/validator) anywhere in the tree
*-keypair.json

# ── Local agent/tooling bloat — not source, never commit (added 2026-06-16) ──
# .claude/ = local worktrees + scheduler lock; .codex-whirlpools/ = local tooling state
/.claude/
/.codex-whirlpools/
