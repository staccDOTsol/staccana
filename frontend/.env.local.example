# Staccana frontend env config.
#
# All NEXT_PUBLIC_* values are inlined into the client bundle at build time.
# Anything sensitive (none today) would live in unprefixed env vars.

# Staccana custom RPC. Defaults to the production endpoint when unset.
NEXT_PUBLIC_RPC_URL=https://rpc.mp.fun/

# URL for the staccana genesis-output snapshot. Returns the GenesisOutput JSON
# (claimable_root, treasury_pda, accounts[]) per snapshot-fork's convention.
NEXT_PUBLIC_SNAPSHOT_URL=https://snapshot.mp.fun/genesis-output.json

# Block explorer base URL. Used to format tx-signature links in success toasts.
NEXT_PUBLIC_EXPLORER_URL=https://explorer.mp.fun

# Display label for the cluster banner. Stays as a config knob so the same
# bundle can ship to mainnet-sigma and a future devnet/testnet without rebuild.
NEXT_PUBLIC_CLUSTER_NAME=mainnet-sigma

# Optional: known genesis hash to display in the cluster banner. If unset, the
# banner just shows the cluster name + RPC. Real value will be pinned in the
# release notes at launch.
NEXT_PUBLIC_GENESIS_HASH=
