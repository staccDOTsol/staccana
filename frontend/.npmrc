# Force pnpm to use a hoisted node_modules layout (no symlinks).
#
# Why: Vercel's serverless deploy package format rejects files inside
# symlinked directories with "The framework produced an invalid deployment
# package for a Serverless Function. Typically this means that the framework
# produces files in symlinked directories." With pnpm's default isolated
# linker, every package under node_modules/<name>/ is a symlink into
# node_modules/.pnpm/<name>@<ver>/node_modules/<name>/. When
# experimental.outputFileTracingIncludes copies @staccoverflow/zk-proofs-wasm's
# .wasm sibling into the function bundle, the tracer follows the symlink and
# the file ends up under a symlinked path in the bundle — Vercel rejects.
#
# `node-linker=hoisted` makes pnpm install packages directly under
# node_modules/<name>/ as flat dirs (npm-style), no .pnpm sandbox, no
# symlinks. Slightly slower install, no behavior difference at runtime.
node-linker=hoisted
